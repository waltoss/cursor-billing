<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.theodo.cursor-billing</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>eval "$(fnm env)" &amp;&amp; node src/index.mjs</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/waltoss/Code/Theodo/Playground/cursor-billing</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Day</key>
    <integer>15</integer>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/waltoss/Code/Theodo/Playground/cursor-billing/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/waltoss/Code/Theodo/Playground/cursor-billing/stderr.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
